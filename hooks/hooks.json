{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/install-deps.mjs\""
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".claude/specs/**",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'specmanager: specs changed — re-read affected docs before acting'"
          }
        ]
      }
    ]
  }
}
