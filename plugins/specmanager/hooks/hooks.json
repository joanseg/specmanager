{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/server/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_DATA}\" && cp \"${CLAUDE_PLUGIN_ROOT}/server/package.json\" . && npm install --omit=dev --no-audit --no-fund) || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\""
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".claude/specs/**",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'specmanager: specs changed — re-read affected docs before acting'"
          }
        ]
      }
    ]
  }
}
